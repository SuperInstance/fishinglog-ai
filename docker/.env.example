# FishingLog.ai — Environment Variables
# Copy to .env and configure for your vessel

# Vessel Identity
VESSEL_ID=vessel-default
VESSEL_NAME=F/V My Vessel
REGION=pacific-nw

# Inference
INFERENCE_PORT=8080
INFERENCE_HOST=localhost

# Cloud Sync (optional)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# LLM (for captain chat)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Logging
LOG_LEVEL=info
NODE_ENV=production
